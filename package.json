{
  "name": "asyncai",
  "version": "1.0.0",
  "description": "Persistent AI agents with their own computers",
  "main": "src/main/main.js",
  "scripts": {
    "build": "webpack --mode production",
    "start": "electron .",
    "dev": "concurrently -k -n webpack,electron -c blue,green \"webpack --mode development --watch\" \"cross-env NODE_ENV=development electron .\"",
    "dist": "npm run build && electron-builder --win --publish never",
    "dist:publish": "npm run build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.asyncai.app",
    "productName": "AsyncAI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "node_modules/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/.cache/**/*",
      "!Dockerfile",
      "!docker/**/*"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Baker-Harrison",
      "repo": "AsyncAI"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "css-loader": "^6.10.0",
    "electron": "^29.0.0",
    "electron-builder": "^26.15.3",
    "electron-reload": "^2.0.0-alpha.1",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "agentation": "^3.0.2",
    "electron-updater": "^6.8.9",
    "marked": "^18.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.14.1"
  }
}
