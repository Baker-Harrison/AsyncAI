{
  "name": "asyncai",
  "version": "1.0.15",
  "description": "Persistent AI agents with their own computers",
  "author": "Baker-Harrison",
  "main": "src/main/main.js",
  "scripts": {
    "build": "webpack --mode production",
    "start": "electron .",
    "dev": "concurrently -k -n webpack,electron -c blue,green \"webpack --mode development --watch\" \"cross-env NODE_ENV=development electron .\"",
    "dist": "npm run build && electron-builder --win --publish never",
    "dist:publish": "npm run build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.asyncai.app",
    "productName": "AsyncAI",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "node_modules/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/.cache/**/*",
      "!Dockerfile",
      "!docker/**/*"
    ],
    "asarUnpack": [
      "node_modules/sql.js/dist/*.wasm",
      "node_modules/node-pty/prebuilds/**/*",
      "node_modules/node-pty/build/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "Baker-Harrison",
      "repo": "AsyncAI",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.29.7",
    "@electron/rebuild": "^4.0.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-jest": "^30.4.1",
    "babel-loader": "^9.1.3",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "css-loader": "^6.10.0",
    "electron": "^29.0.0",
    "electron-builder": "^26.15.3",
    "electron-reload": "^2.0.0-alpha.1",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.9",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-virtuoso": "^4.18.10",
    "sql.js": "^1.14.1"
  }
}
